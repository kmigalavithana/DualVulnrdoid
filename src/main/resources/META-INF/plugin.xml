<!--                groupName="Security"-->
<!--                enabledByDefault="true"-->
<!--                implementationClass="com.dualvulndroid.dualvulndroid.CodeSentinelInspection"/>-->

<!--    </extensions>-->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="MyToolWindow"
                factoryClass="com.dualvulndroid.dualvulndroid.MyToolWindowFactory"
                icon="AllIcons.Toolwindows.ToolWindowPalette"/>

        <!-- පරණ localInspection එක වෙනුවට මේක දාන්න -->
        <externalAnnotator
                language="kotlin"
                implementationClass="com.dualvulndroid.dualvulndroid.CodeSentinelAnnotator"/>
        <externalAnnotator
                language="JAVA"
                implementationClass="com.dualvulndroid.dualvulndroid.CodeSentinelAnnotator"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true" />
    </extensions>
</idea-plugin>